VITE_API_BASE_URL=https://test.bisbsboss.com/api/v1
# VITE_API_BASE_URL=http://localhost:8000/api/v1
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Virtual Card — Bridgecard Integration
# Same value as BRIDGECARD_API_KEY in blocpoint-api/.env
VITE_BRIDGECARD_API_KEY=at_test_
# Evervault relay URL for secure PAN/CVV reveal (fallback — backend returns it per-request)
VITE_BRIDGECARD_EVERVAULT_RELAY_URL=https://strict-relay.evervault.com

